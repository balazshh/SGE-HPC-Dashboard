# Copy to scripts/hpc/collector.env on the HPC side.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=hpc_dashboard
DB_USER=hpc_dashboard
DB_PASSWORD=change-me

# Scheduler host timezone used by qstat/qacct output.
HPC_TZ=Europe/Budapest

# Override only if commands differ on your cluster.
QSTAT_CLUSTER_COMMAND=qstat -g c
QSTAT_JOBS_COMMAND=qstat -u '*'
QACCT_COMMAND=qacct

# Optional local test inputs instead of live commands.
# QSTAT_CLUSTER_FILE=/path/to/qstat-g-c.sample.txt
# QSTAT_JOBS_FILE=/path/to/qstat-u-all.sample.txt
# QACCT_FILE=/path/to/qacct.sample.txt
